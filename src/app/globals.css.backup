@import "tailwindcss";

:root {
  --background: #ffffff;
  --foreground: #1a1a1a;
  --zen-gray: #6b7280;
  --zen-light: #f8fafc;
  --zen-border: #e2e8f0;
  --circle-primary: #000000;
  --circle-secondary: #94a3b8;
}

@theme inline {
  --color-background: var(--background);
  --color-foreground: var(--foreground);
  --font-sans: var(--font-geist-sans);
  --font-mono: var(--font-geist-mono);
}

@media (prefers-color-scheme: dark) {
  :root {
    --background: #0a0a0a;
    --foreground: #ffffff;
    --zen-gray: #d1d5db;
    --zen-light: #1f2937;
    --zen-border: #374151;
    --circle-primary: #ffffff;
    --circle-secondary: #9ca3af;
  }
}

body {
  background: var(--background);
  color: var(--foreground);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;
  font-weight: 300;
  line-height: 1.6;
}

/* 禅意圆环组件 */
.zen-circle {
  position: relative;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.zen-circle::before {
  content: '';
  position: absolute;
  border: 1px solid var(--circle-primary);
  border-radius: 50%;
  animation: zen-pulse 4s ease-in-out infinite;
}

.zen-circle-sm::before {
  width: 24px;
  height: 24px;
}

.zen-circle-md::before {
  width: 48px;
  height: 48px;
}

.zen-circle-lg::before {
  width: 120px;
  height: 120px;
}

.zen-circle-xl::before {
  width: 200px;
  height: 200px;
}

@keyframes zen-pulse {
  0%, 100% { 
    opacity: 0.3; 
    transform: scale(0.95);
  }
  50% { 
    opacity: 0.8; 
    transform: scale(1.05);
  }
}

/* 时间圆环样式 */
.time-circle {
  stroke: var(--circle-primary);
  fill: none;
  stroke-width: 2;
  stroke-linecap: round;
  animation: time-draw 2s ease-out;
}

@keyframes time-draw {
  from {
    stroke-dasharray: 0 628;
  }
  to {
    stroke-dasharray: 628 0;
  }
}

/* 极简卡片样式 */
.zen-card {
  background: var(--background);
  border: 1px solid var(--zen-border);
  border-radius: 2px;
  padding: 3rem;
  margin: 2rem 0;
  transition: all 0.3s ease;
}

.zen-card:hover {
  border-color: var(--circle-primary);
  box-shadow: 0 0 0 1px var(--circle-primary);
}

/* 移动端卡片适配 */
@media (max-width: 640px) {
  .zen-card {
    padding: 1.5rem;
    margin: 1rem 0;
  }
}

/* 极简导航 */
.zen-nav {
  border-bottom: 1px solid var(--zen-border);
  background: rgba(255, 255, 255, 0.8);
  backdrop-filter: blur(8px);
}

@media (prefers-color-scheme: dark) {
  .zen-nav {
    background: rgba(10, 10, 10, 0.8);
  }
}

/* 文字样式 */
.zen-title {
  font-weight: 200;
  letter-spacing: 0.05em;
  color: var(--foreground);
}

.zen-subtitle {
  font-weight: 300;
  color: var(--zen-gray);
  letter-spacing: 0.02em;
}

/* 深色模式下的文字对比度增强 */
@media (prefers-color-scheme: dark) {
  .zen-title {
    color: #ffffff;
  }
  
  .zen-subtitle {
    color: #e5e7eb;
  }
  
  .zen-article {
    color: #f9fafb;
  }
  
  .zen-article h1, .zen-article h2, .zen-article h3 {
    color: #ffffff;
  }
  
  .zen-article blockquote {
    color: #d1d5db;
  }
}

/* 极简按钮 */
.zen-button {
  background: transparent;
  border: 1px solid var(--circle-primary);
  color: var(--circle-primary);
  padding: 0.75rem 2rem;
  font-weight: 300;
  letter-spacing: 0.02em;
  transition: all 0.3s ease;
}

.zen-button:hover {
  background: var(--circle-primary);
  color: var(--background);
}

/* 禅意文章样式 */
.zen-article {
  line-height: 2;
  font-size: 1.1rem;
  font-weight: 300;
  color: var(--foreground);
}

.zen-article h1, .zen-article h2, .zen-article h3 {
  font-weight: 400;
  color: var(--foreground);
  margin: 2rem 0 1rem 0;
  letter-spacing: 0.02em;
}

.zen-article h1 { font-size: 1.8rem; }
.zen-article h2 { font-size: 1.5rem; }
.zen-article h3 { font-size: 1.3rem; }

.zen-article p {
  margin: 1.5rem 0;
  text-align: justify;
}

.zen-article blockquote {
  border-left: 1px solid var(--circle-primary);
  padding-left: 2rem;
  margin: 2rem 0;
  font-style: italic;
  color: var(--zen-gray);
}

.zen-article ul, .zen-article ol {
  margin: 1.5rem 0;
  padding-left: 2rem;
}

.zen-article li {
  margin: 0.5rem 0;
}

.zen-article code {
  background: var(--zen-light);
  padding: 0.2rem 0.4rem;
  border-radius: 2px;
  font-family: var(--font-mono);
  font-size: 0.9em;
}

.zen-article pre {
  background: var(--zen-light);
  padding: 1.5rem;
  border-radius: 2px;
  overflow-x: auto;
  margin: 1.5rem 0;
}

.zen-article img {
  max-width: 100%;
  height: auto;
  margin: 2rem auto;
  display: block;
  filter: grayscale(100%);
}

.zen-article a {
  color: var(--circle-primary);
  text-decoration: none;
  border-bottom: 1px solid transparent;
  transition: border-color 0.3s ease;
}

.zen-article a:hover {
  border-bottom-color: var(--circle-primary);
}

/* 移动端阅读体验优化 */
.mobile-optimized {
  line-height: 1.75;
}

@media (max-width: 640px) {
  .mobile-optimized {
    font-size: 16px;
    line-height: 1.8;
  }

  .mobile-optimized p {
    margin-bottom: 1.5rem !important;
    line-height: 1.8 !important;
    text-align: left !important;
  }

  .mobile-optimized h1,
  .mobile-optimized h2,
  .mobile-optimized h3,
  .mobile-optimized h4 {
    margin-top: 2rem !important;
    margin-bottom: 1rem !important;
    line-height: 1.4 !important;
  }

  .mobile-optimized h4 {
    font-size: 1.1rem !important;
    font-weight: 600 !important;
  }

  .mobile-optimized img {
    margin: 1.5rem 0 !important;
    border-radius: 8px !important;
    max-width: 100% !important;
    height: auto !important;
  }

  .mobile-optimized blockquote {
    margin: 1.5rem 0 !important;
    padding: 1rem !important;
    font-size: 0.95rem !important;
    line-height: 1.7 !important;
  }

  .mobile-optimized strong {
    font-weight: 600 !important;
  }

  /* 优化按钮触摸体验 */
  .zen-button {
    min-height: 44px;
    padding: 12px 24px;
    font-size: 16px;
  }
}

/* ========== Playground Animations ========== */

/* Orbiting circles animation */
.zen-circle-orbit {
  position: absolute;
  border: 1px solid;
  border-color: var(--circle-primary);
  opacity: 0.1;
  border-radius: 50%;
  pointer-events: none;
}

.zen-circle-orbit-1 {
  width: 300px;
  height: 300px;
  top: 10%;
  left: 5%;
  animation: orbit-float 20s ease-in-out infinite;
}

.zen-circle-orbit-2 {
  width: 200px;
  height: 200px;
  bottom: 15%;
  right: 10%;
  animation: orbit-float 15s ease-in-out infinite reverse;
}

.zen-circle-orbit-3 {
  width: 150px;
  height: 150px;
  top: 50%;
  right: 5%;
  animation: orbit-float 25s ease-in-out infinite;
}

@keyframes orbit-float {
  0%, 100% {
    transform: translate(0, 0) rotate(0deg);
    opacity: 0.05;
  }
  25% {
    transform: translate(30px, -20px) rotate(90deg);
    opacity: 0.15;
  }
  50% {
    transform: translate(0, -40px) rotate(180deg);
    opacity: 0.1;
  }
  75% {
    transform: translate(-30px, -20px) rotate(270deg);
    opacity: 0.15;
  }
}

/* Slow spin animation */
@keyframes spin-slow {
  from {
    transform: rotate(0deg);
  }
  to {
    transform: rotate(360deg);
  }
}

.animate-spin-slow {
  animation: spin-slow 30s linear infinite;
}

/* Subtle bounce animation */
@keyframes bounce-subtle {
  0%, 100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-10px);
  }
}

.animate-bounce-subtle {
  animation: bounce-subtle 3s ease-in-out infinite;
}

/* Scroll dot animation */
@keyframes scroll-dot {
  0%, 100% {
    transform: translateY(-8px);
    opacity: 0;
  }
  50% {
    transform: translateY(8px);
    opacity: 1;
  }
}

.animate-scroll-dot {
  animation: scroll-dot 2s ease-in-out infinite;
}

/* Fade in stagger animation */
@keyframes fade-in-up {
  from {
    opacity: 0;
    transform: translateY(30px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.animate-fade-in-up {
  animation: fade-in-up 0.8s ease-out forwards;
}

/* Ripple effect */
@keyframes ripple {
  0% {
    transform: scale(0);
    opacity: 1;
  }
  100% {
    transform: scale(4);
    opacity: 0;
  }
}

.ripple-effect::after {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: 50%;
  border: 1px solid currentColor;
  animation: ripple 1.5s ease-out infinite;
}

/* Slide in animations */
@keyframes slide-in-left {
  from {
    transform: translateX(-100%);
    opacity: 0;
  }
  to {
    transform: translateX(0);
    opacity: 1;
  }
}

@keyframes slide-in-right {
  from {
    transform: translateX(100%);
    opacity: 0;
  }
  to {
    transform: translateX(0);
    opacity: 1;
  }
}

.animate-slide-in-left {
  animation: slide-in-left 0.6s ease-out;
}

.animate-slide-in-right {
  animation: slide-in-right 0.6s ease-out;
}

/* Scale animation */
@keyframes scale-in {
  from {
    transform: scale(0.8);
    opacity: 0;
  }
  to {
    transform: scale(1);
    opacity: 1;
  }
}

.animate-scale-in {
  animation: scale-in 0.5s ease-out;
}

/* Shimmer loading effect */
@keyframes shimmer {
  0% {
    background-position: -1000px 0;
  }
  100% {
    background-position: 1000px 0;
  }
}

.shimmer {
  background: linear-gradient(
    90deg,
    var(--zen-light) 0%,
    var(--zen-border) 50%,
    var(--zen-light) 100%
  );
  background-size: 1000px 100%;
  animation: shimmer 2s infinite;
}

/* Skeleton loading */
.skeleton {
  background: var(--zen-light);
  position: relative;
  overflow: hidden;
}

.skeleton::after {
  content: '';
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  background: linear-gradient(
    90deg,
    transparent,
    rgba(255, 255, 255, 0.4),
    transparent
  );
  animation: skeleton-loading 1.5s infinite;
}

@media (prefers-color-scheme: dark) {
  .skeleton::after {
    background: linear-gradient(
      90deg,
      transparent,
      rgba(255, 255, 255, 0.1),
      transparent
    );
  }
}

@keyframes skeleton-loading {
  0% {
    transform: translateX(-100%);
  }
  100% {
    transform: translateX(100%);
  }
}
